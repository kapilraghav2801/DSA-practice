def delete_middle(stack,k,current = 1):
    if current == k :
        stack.pop()
        return 
    temp = stack.pop()
    delete_middle(stack,k,current + 1)
    stack.append(temp)

def remove_middle(stack):
    n = len(stack)
    k = n//2 + 1

    delete_middle(stack,k)
    return stack


stack = [3,5,4,1,8] 

result = remove_middle(stack)

print(result)